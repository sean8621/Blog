# ========== 解决 ERR_PNPM_IGNORED_BUILDS 核心配置 ==========
# 永久放行必须执行构建脚本的核心包（esbuild/vue-demi 必加）
approve-builds=esbuild,vue-demi

# 兼容 vite、vitepress 项目常用依赖（可选补充，避免后续再弹窗）
public-hoist-pattern[]=esbuild
public-hoist-pattern[]=vue-demi
public-hoist-pattern[]=*.esbuild
public-hoist-pattern[]=vue-demi/*

# ========== 修复开头警告：package.json pnpm.peerDependencyRules 迁移 ==========
# 对等依赖宽松规则，消除 peer 版本冲突警告，适配 Vue 项目
peerDependencyRules.@vue/*@>=3.0.0=ignore
peerDependencyRules.vue@>=3=ignore

# ========== 通用pnpm优化配置（前端项目通用） ==========
# 自动安装缺失 peer 依赖，不用手动装
auto-install-peers=true
# 提升依赖到 node_modules 根目录，解决vue/类型包导入找不到
shamefully-hoist=true
# 锁定依赖版本严格匹配 lockfile
strict-peer-dependencies=false
# 关闭多余日志输出
loglevel=info
# 统一仓库源，加速国内下载
registry=https://registry.npmmirror.com
# 不自动更新 lockfile 版本
lockfile-version=9
# 供应链校验（你日志里用到的锁文件校验）
verify-lockfile=true